      objectReference: {fileID: 0}
    - target: {fileID: 7316411270777083970, guid: 739b32b9d5b4c0b4eb5b32e401d9008c, type: 3}
      propertyPath: m_text
      value: "\u041F\u043E\u0441\u043B\u0435 \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
        \u0440\u0430\u0437\u0433\u0440\u043E\u043C\u0430 \u0443 \u0421\u043E\u043B\u0435\u043D\u0438\u043A\u043E\u0432\u043E\u0439
        \u0432\u0430\u0442\u0430\u0433\u0438 \u041F\u0443\u0433\u0430\u0447\u0451\u0432
        \u0441 \u0433\u043E\u0440\u0441\u0442\u043A\u043E\u0439 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u0445
        \u0441\u043E\u0440\u0430\u0442\u043D\u0438\u043A\u043E\u0432 \u0431\u0435\u0436\u0430\u043B
        \u0432 \u0437\u0430\u0432\u043E\u043B\u0436\u0441\u043A\u0438\u0435 \u0441\u0442\u0435\u043F\u0438.
        \u041B\u0438\u0448\u0451\u043D\u043D\u044B\u0439 \u0430\u0440\u043C\u0438\u0438
        \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438, \u043E\u043D
        \u0431\u044B\u043B \u043F\u0440\u0435\u0434\u0430\u043D \u0441\u0432\u043E\u0438\u043C\u0438
        \u0436\u0435 \u043A\u0430\u0437\u0430\u043A\u0430\u043C\u0438 \u0438 8 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
        1774 \u0433\u043E\u0434\u0430 \u0432\u044B\u0434\u0430\u043D \u0432\u043B\u0430\u0441\u0442\u044F\u043C.
        \u0417\u0430\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E \u0432
        \u043A\u0430\u043D\u0434\u0430\u043B\u044B \xAB\u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
        \u041F\u0435\u0442\u0440\u0430 III\xBB \u0432 \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0439
        \u043A\u043B\u0435\u0442\u043A\u0435 \u043E\u0442\u0432\u0435\u0437\u043B\u0438
        \u0432 \u041C\u043E\u0441\u043A\u0432\u0443. 10 \u044F\u043D\u0432\u0430\u0440\u044F
        1775 \u0433\u043E\u0434\u0430 \u043D\u0430 \u0411\u043E\u043B\u043E\u0442\u043D\u043E\u0439
        \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u0415\u043C\u0435\u043B\u044C\u044F\u043D
        \u041F\u0443\u0433\u0430\u0447\u0451\u0432 \u0431\u044B\u043B \u043A\u0430\u0437\u043D\u0451\u043D.
        \u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0441\u043A\u043E\u0435
        \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0438\u0435, \u043F\u043E\u0442\u0440\u044F\u0441\u0448\u0435\u0435
        \u0438\u043C\u043F\u0435\u0440\u0438\u044E, \u0431\u044B\u043B\u043E \u0436\u0435\u0441\u0442\u043E\u043A\u043E
        \u043F\u043E\u0434\u0430\u0432\u043B\u0435\u043D\u043E"
      objectReference: {fileID: 0}
